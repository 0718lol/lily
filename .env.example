# Copy this file to .env and fill in the values you need.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
LILY_USE_CODEX=true
LILY_CODEX_PATH=/Applications/ChatGPT.app/Contents/Resources/codex
LILY_CODEX_TIMEOUT=900
# Additional environment variable names Codex may inherit, comma-separated.
LILY_CODEX_ENV_ALLOWLIST=
LILY_USE_CLAUDE=true
LILY_CLAUDE_PATH=
LILY_CLAUDE_CONFIG_PATH=
LILY_CLAUDE_PROVIDER=
LILY_CLAUDE_MODEL=
LILY_CLAUDE_TIMEOUT=900
LILY_CLAUDE_MAX_TURNS=30
# Extra environment names are opt-in; saved Claude login normally only needs HOME.
LILY_CLAUDE_ENV_ALLOWLIST=
# Add project-specific test commands explicitly, for example Bash(pytest:*).
LILY_CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep,Edit,Write,Bash(git status:*),Bash(git diff:*)
LILY_RUNTIME_PRIORITY=codex-cli,claude-code
LILY_ALLOWED_REPO_ROOT=/Users/you
LILY_WORKTREE_DIR=lily-worktrees
LILY_DB_PATH=lily.db
LILY_WORKER_INTERVAL=2
LILY_HEARTBEAT_INTERVAL=10
LILY_LEASE_TIMEOUT=60
LILY_MAX_ATTEMPTS=3
